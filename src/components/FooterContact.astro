---
// FooterContact.astro - Curtain Reveal Footer with Minimalist Links

const links = [
  { label: "EMAIL", url: "mailto:abdazissyam@gmail.com" },
  { label: "GITHUB", url: "https://github.com/AzisSyam" },
  { label: "LINKEDIN", url: "https://linkedin.com/in/azissyam" },
  { label: "TWITTER / X", url: "https://x.com/AzisSyam" }
];
---

<!-- Tall parent: gives the Contact a scroll zone so it stays visible after Stats is scrolled past -->
<div id="contact" class="relative z-50 h-[200vh] mt-[-100vh]">
  <footer id="contact-footer" class="sticky top-0 h-screen w-full bg-brand-bg text-brand-primary flex flex-col justify-between p-8 md:p-16 border-t border-brand-primary/20 overflow-hidden shadow-[0_-10px_30px_rgba(0,0,0,0.3)]">
    <!-- Top Section: Dynamic Contact Prompt -->
    <div class="max-w-7xl mx-auto w-full flex flex-col md:flex-row justify-between items-start md:items-end space-y-8 md:space-y-0">
      <div class="space-y-4">
        <span class="text-xs uppercase tracking-widest text-brand-primary/80">Get in touch</span>
        <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-none text-brand-primary">
          LET'S CONNECT.
        </h2>
      </div>
    </div>

    <!-- Middle Section: Minimalist Social Directory -->
    <div class="max-w-7xl mx-auto w-full my-auto py-8">
      <nav class="flex flex-col md:flex-row gap-6 md:gap-12">
        {links.map((link) => (
          <a 
            href={link.url} 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-2xl md:text-3xl font-extrabold tracking-tight text-brand-primary hover:text-brand-primary/80 transition-colors duration-300 relative group w-fit"
          >
            {link.label}
            <!-- Minimal line hover animation -->
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-brand-primary transition-all duration-300 group-hover:w-full"></span>
          </a>
        ))}
      </nav>
    </div>

    <!-- Bottom Section: Legal & Branding -->
    <div class="max-w-7xl mx-auto w-full flex flex-col md:flex-row justify-between items-start md:items-center pt-8 border-t border-brand-primary/10 text-xs text-brand-primary/50 space-y-4 md:space-y-0">
      <div>
        <p>© {new Date().getFullYear()} Abd. Azis Syam. All rights reserved.</p>
      </div>
      <div class="flex space-x-6">
        <span>Designed & Built in Indonesia</span>
      </div>
    </div>
  </footer>
</div>
