---
// Projects.astro - Horizontal scroll projects showcase

const projects = [
  {
    title: "Smart Library Management",
    category: "Full-Stack Web App",
    description: "An automated library platform featuring real-time availability tracking, barcode scanning, and automated overdue email alerts.",
    tech: ["Laravel", "Blade", "Tailwind CSS", "MySQL"],
    image: "https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&q=80&w=800",
    link: "#"
  },
  {
    title: "EcoSphere Analytics",
    category: "SaaS Dashboard",
    description: "Real-time carbon footprint monitoring platform for large scale organizations with detailed exports and data visualizations.",
    tech: ["Next.js", "TypeScript", "Tremor", "PostgreSQL"],
    image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=800",
    link: "#"
  },
  {
    title: "Aura Commerce",
    category: "E-Commerce",
    description: "A headless, high-performance storefront with lightning-fast static generation and instant search filters.",
    tech: ["Astro", "React", "Tailwind CSS", "Stripe"],
    image: "https://images.unsplash.com/photo-1472851294608-062f824d29cc?auto=format&fit=crop&q=80&w=800",
    link: "#"
  },
  {
    title: "VibeSync Studio",
    category: "Audio Platform",
    description: "Collaborative music creation environment directly in the browser with MIDI support and real-time audio synthesis.",
    tech: ["Web Audio API", "WebSockets", "Svelte", "Node.js"],
    image: "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?auto=format&fit=crop&q=80&w=800",
    link: "#"
  }
];
---

<section id="projects" class="relative z-20 h-[500vh] bg-brand-bg text-brand-primary mt-[-100vh] border-t border-brand-primary/20 shadow-[0_-10px_30px_rgba(0,0,0,0.3)]">
  <!-- Sticky Container -->
  <div class="sticky top-0 h-screen w-full overflow-hidden flex flex-col justify-center">
    
    <!-- Top Bar Title -->
    <div class="px-6 md:px-12 w-full max-w-7xl mx-auto flex justify-between items-end mb-12">
      <div class="space-y-2">
        <span class="text-xs uppercase tracking-widest text-brand-primary/80">Featured Showcase</span>
        <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight text-brand-primary">SELECTED WORK</h2>
      </div>
      <div class="hidden md:flex items-center space-x-2 text-xs uppercase tracking-widest text-brand-primary/80">
        <span>Scroll Down</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 13l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>

    <!-- Horizontal Showcase Track -->
    <div class="w-full overflow-hidden">
      <div id="projects-track" class="flex gap-8 px-6 md:px-12 w-max transition-transform duration-75 ease-out will-change-transform">
        {projects.map((project, index) => (
          <div class="w-[85vw] md:w-[450px] flex-shrink-0 group">
            <!-- Project Card Link -->
            <a href={project.link} class="block space-y-6">
              
              <!-- Card Image / Frame -->
              <div class="relative aspect-video w-full overflow-hidden border border-brand-primary/20 bg-brand-bg/50 transition-all duration-500 group-hover:border-brand-primary">
                <img 
                  src={project.image} 
                  alt={project.title} 
                  class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 opacity-80 group-hover:opacity-100"
                  loading="lazy"
                />
                <span class="absolute top-4 left-4 bg-brand-bg/90 px-3 py-1 text-xs border border-brand-primary/20 text-brand-primary tracking-widest uppercase">
                  0{index + 1}
                </span>
              </div>

              <!-- Card Bio -->
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <span class="text-xs uppercase tracking-widest text-brand-primary/80">{project.category}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-300 text-brand-primary/70 group-hover:text-brand-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </div>
                <h3 class="text-2xl font-bold tracking-tight text-brand-primary group-hover:underline decoration-1 underline-offset-4">
                  {project.title}
                </h3>
                <p class="text-sm font-light text-brand-primary/70 line-clamp-2">
                  {project.description}
                </p>
                <div class="flex flex-wrap gap-2 pt-1">
                  {project.tech.map((t) => (
                    <span class="text-[10px] font-medium tracking-wider uppercase px-2.5 py-1 bg-brand-primary/5 border border-brand-primary/20 text-brand-primary rounded-full">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Setup horizontal scroll transition based on window scrolling
  const setupHorizontalScroll = () => {
    // Clean up previous event listener if it exists to prevent memory leaks during page navigation
    if ((window as any)._projectsScrollListener) {
      window.removeEventListener('scroll', (window as any)._projectsScrollListener);
    }

    const parent = document.getElementById('projects');
    const track = document.getElementById('projects-track');
    
    if (!parent || !track) return;

    const onScroll = () => {
      // If the parent is no longer in the DOM, clean up and return
      if (!document.getElementById('projects')) {
        window.removeEventListener('scroll', onScroll);
        return;
      }

      const parentRect = parent.getBoundingClientRect();
      const scrollHeight = parentRect.height - window.innerHeight * 3;
      
      // Calculate scroll progress percentage inside the parent section
      const progress = -parentRect.top / scrollHeight;
      const clampedProgress = Math.max(0, Math.min(1, progress));
      
      // Track width and remaining horizontal space to slide
      const trackWidth = track.scrollWidth;
      const maxTranslate = trackWidth - window.innerWidth;
      
      if (maxTranslate > 0) {
        const xTranslation = clampedProgress * maxTranslate;
        track.style.transform = `translateX(-${xTranslation}px)`;
      }
    };

    window.addEventListener('scroll', onScroll);
    (window as any)._projectsScrollListener = onScroll;
    
    // Initial call to set positions
    onScroll();
  };

  // Run on load and swap
  setupHorizontalScroll();
  document.addEventListener('astro:page-load', setupHorizontalScroll);
</script>
